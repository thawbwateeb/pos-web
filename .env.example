# Public URL the browser uses (for client-side fetches + SSE)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Internal URL the SSR runtime uses (Railway private network on prod,
# same host:port in dev). Falls back to NEXT_PUBLIC_API_URL if unset.
API_URL_INTERNAL=http://localhost:3001

# Version label shown in the login footer.
NEXT_PUBLIC_VERSION=v2.4

# Host where QZ Tray runs (the print bridge). Defaults to localhost — only
# override when QZ Tray runs on a different machine than the browser.
NEXT_PUBLIC_QZ_HOST=localhost
